<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #E9EEF7;" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifba.controller.features.bibliotecario.AdicionarLivroController">
    <top>
        <HBox alignment="CENTER_LEFT" maxHeight="80.0" minHeight="80.0" prefHeight="80.0" style="-fx-background-color: #1A3783;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="40.0" right="40.0" />
            </padding>
            <children>
                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 14px;" text="Bem Vindo" />
                        <Label fx:id="NomeUsuario" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;" text="Nome aqui" />
                    </children>
                </VBox>
                <VBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                    <children>
                        <ImageView fitHeight="250.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../../images/logo.png" />
                            </image>
                        </ImageView>
                    </children>
                </VBox>
                <ImageView fx:id="irParaLogin" fitHeight="35.0" fitWidth="35.0" onMouseClicked="#handleLogout" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../images/botaoSeta.jpeg" />
                    </image>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                    <HBox.margin>
                        <Insets left="20.0" />
                    </HBox.margin>
                </ImageView>
            </children>
        </HBox>
    </top>
    <bottom>
        <HBox alignment="CENTER" maxHeight="90.0" minHeight="90.0" prefHeight="90.0" style="-fx-background-color: white; -fx-background-radius: 25 25 0 0; -fx-border-color: #D1D1D1 transparent transparent transparent; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"><children><ImageView fitHeight="50.0" fitWidth="100.0" onMouseClicked="#dashboardController" pickOnBounds="true" preserveRatio="true"><image><Image url="@../../images/botaoDashboard.jpeg" /></image><cursor><Cursor fx:constant="HAND" /></cursor></ImageView></children></VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"><children><ImageView fitHeight="50.0" fitWidth="100.0" onMouseClicked="#inventarioController" pickOnBounds="true" preserveRatio="true"><image><Image url="@../../images/botaoInventario.jpeg" /></image><cursor><Cursor fx:constant="HAND" /></cursor></ImageView></children></VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"><children><ImageView fitHeight="50.0" fitWidth="100.0" onMouseClicked="#controleDeReservasController" pickOnBounds="true" preserveRatio="true"><image><Image url="@../../images/botaoFilaDeReserva.jpeg" /></image><cursor><Cursor fx:constant="HAND" /></cursor></ImageView></children></VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"><children><ImageView fitHeight="50.0" fitWidth="100.0" onMouseClicked="#controleDeEmprestimosController" pickOnBounds="true" preserveRatio="true"><image><Image url="@../../images/botaoDevolucoes.jpeg" /></image><cursor><Cursor fx:constant="HAND" /></cursor></ImageView></children></VBox>
            </children>
        </HBox>
    </bottom>
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #E9EEF7; -fx-background: #E9EEF7;" vbarPolicy="AS_NEEDED" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="20.0" style="-fx-background-color: #E9EEF7;">
                    <padding>
                        <Insets bottom="50.0" left="60.0" right="60.0" top="30.0" />
                    </padding>
                    <children>
                        <!-- Botão Voltar -->
                        <HBox fx:id="btnVoltar" alignment="CENTER_LEFT" onMouseClicked="#handleVoltar" spacing="10.0">
                            <children>
                                <Label style="-fx-text-fill: #1A3783; -fx-font-weight: bold; -fx-font-size: 16px;" text="⬅ Voltar ao inventário">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Label>
                            </children>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </HBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;" text="Informações do livro" />
                                <Label style="-fx-text-fill: #555555; -fx-font-size: 16px;" text="Controle do acervo físico" />
                            </children>
