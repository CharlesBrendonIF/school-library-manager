                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" GridPane.columnIndex="1">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="ISBN*" />
                                                <TextField fx:id="txtIsbn" prefHeight="50.0" promptText="000-00-000-0000-0" style="-fx-background-color: #E9EEF7; -fx-background-radius: 20; -fx-padding: 0 15;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" GridPane.columnIndex="2">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Categoria / Gênero*" />
                                                <TextField fx:id="txtCategoria" prefHeight="50.0" promptText="Ex: Algoritmos" style="-fx-background-color: #E9EEF7; -fx-background-radius: 20; -fx-padding: 0 15;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" GridPane.rowIndex="1">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Autor*" />
                                                <TextField fx:id="txtAutor" prefHeight="50.0" promptText="Nome do autor" style="-fx-background-color: #E9EEF7; -fx-background-radius: 20; -fx-padding: 0 15;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="ID do exemplar*" />
                                                <TextField fx:id="txtIdExemplar" prefHeight="50.0" promptText="Ex: #COMP-001" style="-fx-background-color: #E9EEF7; -fx-background-radius: 20; -fx-padding: 0 15;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.rowSpan="2">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Descrição*" />
                                                <TextArea fx:id="txtDescricao" prefHeight="160.0" promptText="Sinopse ou detalhes adicionais..." style="-fx-background-color: #E9EEF7; -fx-background-radius: 20; -fx-padding: 10;" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" GridPane.rowIndex="2">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Ano de publicação*" />
                                                <TextField fx:id="txtAno" prefHeight="50.0" promptText="Ex: 2009" style="-fx-background-color: #E9EEF7; -fx-background-radius: 20; -fx-padding: 0 15;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Quantidade*" />
                                                <TextField fx:id="txtQuantidade" prefHeight="50.0" promptText="Ex: 5" style="-fx-background-color: #E9EEF7; -fx-background-radius: 20; -fx-padding: 0 15;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>

                                    <!-- BOTÃO ADICIONAR -->
                                <VBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button fx:id="btnSalvarLivro" mnemonicParsing="false" onAction="#handleSalvarLivro" prefHeight="55.0" prefWidth="300.0" style="-fx-background-color: #27AE60; -fx-background-radius: 25; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 4);" text="ADICIONAR">
                                            <cursor><Cursor fx:constant="HAND" /></cursor>
                                        </Button>
                                        <Label style="-fx-text-fill: #777777; -fx-font-style: italic; -fx-font-size: 14px;" text="* Todos os campos são obrigatórios" />
                                    </children>
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
