<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.biblioqueue.controller.EmprestimosController"
            stylesheets="@../css/biblioqueue.css"
            prefWidth="900" prefHeight="700">

    <!-- ===== TOP BAR ===== -->
    <top>
        <VBox>
            <!-- Navbar preta -->
            <HBox styleClass="top-bar" alignment="CENTER">
                <Label text="BiblioQueue" styleClass="top-bar-title" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Header azul com saudação -->
            <HBox styleClass="user-header" alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Bem-vindo," styleClass="welcome-label"/>
                    <Label fx:id="lblNomeUsuario" text="Ana Silva" styleClass="user-name-label"/>
                </VBox>
                <Button text="→" styleClass="logout-btn" onAction="#onLogout"
                        style="-fx-font-size: 20px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ===== CENTRO ===== -->
    <center>
        <ScrollPane styleClass="scroll-pane" fitToWidth="true"
                    style="-fx-background-color: #E8EEF7;">
            <VBox spacing="14" style="-fx-padding: 24 270 30 270; -fx-background-color: #E8EEF7;">

                <!-- Título da seção -->
                <VBox spacing="2">
                    <Label text="Meus Empréstimos" styleClass="section-title"/>
                    <Label text="Livros em sua posse" styleClass="section-subtitle"/>
                </VBox>

                <!-- ===== ALERTA DE ACESSO BLOQUEADO ===== -->
                <HBox fx:id="alertaBloqueado"
                      styleClass="alert-card"
                      spacing="12"
                      alignment="TOP_LEFT"
                      visible="true"
                      managed="true">
                    <VBox alignment="CENTER" minWidth="32">
                        <Label text="⚠" style="-fx-font-size: 18px; -fx-text-fill: #DC2626;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="⚠" style="-fx-font-size: 13px; -fx-text-fill: #F59E0B;"/>
                            <Label text="Acesso Bloqueado" styleClass="alert-title"/>
                        </HBox>
                        <Label text="Você possui livros em atraso. Regularize suas devoluções para fazer novos empréstimos."
                               styleClass="alert-text"
                               wrapText="true"/>
                    </VBox>
                </HBox>

                <!-- ===== CARD DE EMPRÉSTIMO 1 (Atrasado) ===== -->
                <VBox styleClass="loan-card-atrasado" spacing="12">

                    <!-- Cabeçalho do card -->
                    <HBox spacing="12" alignment="TOP_LEFT">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #FEE2E2; -fx-background-radius: 8; -fx-padding: 10; -fx-min-width: 42px; -fx-min-height: 42px; -fx-max-width: 42px; -fx-max-height: 42px;">
                            <Label text="📕" style="-fx-font-size: 18px;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="4">
                            <Label fx:id="lblTitulo1" text="Estruturas de Dados e Algoritmos"
                                   styleClass="loan-book-title"/>
                            <Label fx:id="lblIdExemplar1" text="#COMP-001" styleClass="loan-book-id"/>
                            <HBox>
                                <Label text="Atrasado" styleClass="tag-atrasado"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Separador -->
                    <Separator style="-fx-background-color: #FECACA;"/>

                    <!-- Datas -->
                    <VBox spacing="8">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📅 " style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            <Label text="Data de Retirada" styleClass="loan-label" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblDataRetirada1" text="07/04/2026" styleClass="loan-value"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📅 " style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            <Label text="Data Prevista" styleClass="loan-label" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblDataPrevista1" text="14/04/2026" styleClass="loan-value-atrasado"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="⏰ " style="-fx-font-size: 12px;"/>
                            <Label fx:id="lblAtraso1" text="Atrasado há 16 dia(s)"
                                   styleClass="loan-atraso-label"/>
                        </HBox>
                    </VBox>

                    <!-- Rodapé -->
                    <HBox alignment="CENTER">
                        <Label text="ID de Log: 1" styleClass="loan-id-label"/>
                    </HBox>
                </VBox>

                <!-- ===== CARD DE EMPRÉSTIMO 2 (Atrasado) ===== -->
                <VBox styleClass="loan-card-atrasado" spacing="12">

                    <HBox spacing="12" alignment="TOP_LEFT">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #FEE2E2; -fx-background-radius: 8; -fx-padding: 10; -fx-min-width: 42px; -fx-min-height: 42px; -fx-max-width: 42px; -fx-max-height: 42px;">
                            <Label text="📕" style="-fx-font-size: 18px;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="4">
                            <Label fx:id="lblTitulo2" text="Engenharia de Software"
                                   styleClass="loan-book-title"/>
                            <Label fx:id="lblIdExemplar2" text="#COMP-003" styleClass="loan-book-id"/>
                            <HBox>
                                <Label text="Atrasado" styleClass="tag-atrasado"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <Separator style="-fx-background-color: #FECACA;"/>

                    <VBox spacing="8">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📅 " style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            <Label text="Data de Retirada" styleClass="loan-label" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblDataRetirada2" text="09/04/2026" styleClass="loan-value"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📅 " style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            <Label text="Data Prevista" styleClass="loan-label" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblDataPrevista2" text="16/04/2026" styleClass="loan-value-atrasado"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="⏰ " style="-fx-font-size: 12px;"/>
                            <Label fx:id="lblAtraso2" text="Atrasado há 14 dia(s)"
                                   styleClass="loan-atraso-label"/>
                        </HBox>
                    </VBox>

                    <HBox alignment="CENTER">
                        <Label text="ID de Log: 2" styleClass="loan-id-label"/>
                    </HBox>
                </VBox>

                <!-- Container para cards adicionais gerados dinamicamente -->
                <VBox fx:id="listaEmprestimosContainer" spacing="12"/>

                <!-- Mensagem quando não há empréstimos (oculto por padrão) -->
                <VBox fx:id="emptyStateEmprestimos"
                      styleClass="empty-card"
                      spacing="16"
                      alignment="CENTER"
                      visible="false"
                      managed="false">
                    <VBox styleClass="empty-icon-circle" alignment="CENTER">
                        <Label text="📗" style="-fx-font-size: 26px;"/>
                    </VBox>
                    <Label text="Nenhum empréstimo ativo" styleClass="empty-title"/>
                    <Label text="Você não possui livros emprestados no momento"
                           styleClass="empty-subtitle" wrapText="true"
                           style="-fx-text-alignment: center;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- ===== BOTTOM NAV ===== -->
    <bottom>
        <HBox styleClass="bottom-bar" alignment="CENTER" spacing="0">

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavCatalogo" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="📖" style="-fx-font-size: 20px; -fx-text-fill: #94A3B8;"/>
                <Label text="Catálogo" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
            </VBox>

            <!-- Empréstimos (ativo) -->
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavEmprestimos" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="📗" style="-fx-font-size: 20px; -fx-text-fill: #1E3A8A;"/>
                <Label text="Empréstimos" style="-fx-font-size: 11px; -fx-text-fill: #1E3A8A; -fx-font-weight: bold;"/>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavReservas" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="🕐" style="-fx-font-size: 20px; -fx-text-fill: #94A3B8;"/>
                <Label text="Reservas" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>
