<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifba.controller.features.usuario.DetalheLivroController"
            stylesheets="@css/biblioqueue.css"
            prefWidth="900" prefHeight="700">

    <!-- ===== TOP BAR ===== -->
    <top>
        <VBox>
            <!-- Navbar preta -->
            <HBox styleClass="top-bar" alignment="CENTER">
                <Label text="BiblioQueue" styleClass="top-bar-title" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Header azul com nome do usuário -->
            <HBox styleClass="user-header" alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Bem-vindo," styleClass="welcome-label"/>
                    <Label fx:id="lblNomeUsuario" text="Ana Silva" styleClass="user-name-label"/>
                </VBox>
                <Button text="→" styleClass="logout-btn" onAction="#onLogout"
                        style="-fx-font-size: 20px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ===== CENTRO ===== -->
    <center>
        <ScrollPane styleClass="scroll-pane" fitToWidth="true"
                    style="-fx-background-color: #E8EEF7;">
            <VBox spacing="16" style="-fx-padding: 20 270 30 270; -fx-background-color: #E8EEF7;">

                <!-- Botão Voltar -->
                <HBox>
                    <Button fx:id="btnVoltar"
                            text="← Voltar ao catálogo"
                            styleClass="back-btn"
                            onAction="#onVoltar"/>
                </HBox>

                <!-- Card principal do livro -->
                <VBox styleClass="detail-card" spacing="14">

                    <!-- Ícone + Título + Autor + Ano -->
                    <HBox spacing="16" alignment="TOP_LEFT">
                        <VBox alignment="CENTER" styleClass="detail-icon-box"
                              minWidth="56" minHeight="56" maxWidth="56" maxHeight="56">
                            <Label text="📖" style="-fx-font-size: 24px;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblTitulo"
                                   text="Estruturas de Dados e Algoritmos"
                                   styleClass="detail-title"
                                   wrapText="true"/>
                            <Label fx:id="lblAutor" text="Thomas H. Cormen" styleClass="detail-author"/>
                            <Label fx:id="lblAno" text="2009" styleClass="detail-author"/>
                            <!-- Tag categoria -->
                            <HBox spacing="6" style="-fx-padding: 6 0 0 0;">
                                <Label fx:id="lblCategoria" text="Algoritmos" styleClass="tag-category"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Separador -->
                    <Separator style="-fx-background-color: #F1F5F9;"/>

                    <!-- Campos de detalhes -->
                    <VBox spacing="10">

                        <HBox>
                            <Label text="ISBN" styleClass="detail-field-label" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblIsbn" text="978-0262033848" styleClass="detail-field-value"/>
                        </HBox>

                        <HBox>
                            <Label text="Data de Publicação" styleClass="detail-field-label" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblDataPublicacao" text="2009" styleClass="detail-field-value"/>
                        </HBox>

                        <HBox>
                            <Label text="Disponibilidade" styleClass="detail-field-label" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblDisponibilidade" text="2 exemplar(es)" styleClass="detail-field-value-green"/>
                        </HBox>
                    </VBox>

                    <!-- Box de descrição -->
                    <VBox styleClass="detail-description-box">
                        <Label fx:id="lblDescricao"
                               text="Referência completa sobre estruturas de dados e algoritmos computacionais."
                               styleClass="detail-description-text"
                               wrapText="true"/>
                    </VBox>

                    <VBox fx:id="actionContainer" spacing="8">

                        <HBox fx:id="alertaBloqueado" styleClass="alert-card" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
                            <Label text="⚠" style="-fx-font-size: 14px; -fx-text-fill: #DC2626;"/>
                            <VBox>
                                <Label text="Acesso Bloqueado:" style="-fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                                <Label text="Regularize seus atrasos primeiro." styleClass="alert-text"/>
                            </VBox>
                        </HBox>

                        <HBox fx:id="alertaLimite" styleClass="alert-card" style="-fx-border-color: #EAB308; -fx-background-color: #FEFCE8;" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
                            <Label text="⚠" style="-fx-font-size: 14px; -fx-text-fill: #A16207;"/>
                            <Label text="Você atingiu seu limite de empréstimos ativos." style="-fx-text-fill: #A16207; -fx-font-size: 13px;"/>
                        </HBox>

                        <HBox fx:id="alertaJaPossui" styleClass="alert-card" style="-fx-border-color: #2563EB; -fx-background-color: #EFF6FF;" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
                            <Label text="ℹ" style="-fx-font-size: 14px; -fx-text-fill: #1E40AF;"/>
                            <Label text="Você já está em posse de um exemplar deste título." style="-fx-text-fill: #1E40AF; -fx-font-size: 13px;"/>
                        </HBox>

                        <HBox fx:id="alertaJaReservado" styleClass="alert-card" style="-fx-border-color: #EA580C; -fx-background-color: #FFF7ED;" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false">
                            <Label text="⏳" style="-fx-font-size: 14px; -fx-text-fill: #9A3412;"/>
                            <Label text="Você já está na fila de reserva para este livro." style="-fx-text-fill: #9A3412; -fx-font-size: 13px;"/>
                        </HBox>

                        <Button fx:id="btnEmprestimo" text="Pegar Emprestado" visible="false" managed="false" onAction="#onEmprestimo" styleClass="primary-btn"/>
                        <Button fx:id="btnReserva" text="Entrar na Fila de Espera" visible="false" managed="false" onAction="#onReserva" styleClass="secondary-btn"/>
                    </VBox>

                    <!-- Rodapé do card -->
                    <HBox alignment="CENTER">
                        <Label fx:id="lblEmprestimosAtivos"
                               text="Empréstimos ativos: 2/3"
                               styleClass="detail-active-loans"/>
                    </HBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ===== BOTTOM NAV ===== -->
    <bottom>
        <HBox styleClass="bottom-bar" alignment="CENTER" spacing="0">

            <!-- Catálogo (ativo nesta tela pois viemos do catálogo) -->
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavCatalogo" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="📖" style="-fx-font-size: 20px; -fx-text-fill: #1E3A8A;"/>
                <Label text="Catálogo" style="-fx-font-size: 11px; -fx-text-fill: #1E3A8A; -fx-font-weight: bold;"/>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavEmprestimos" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="📗" style="-fx-font-size: 20px; -fx-text-fill: #94A3B8;"/>
                <Label text="Empréstimos" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavReservas" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="🕐" style="-fx-font-size: 20px; -fx-text-fill: #94A3B8;"/>
                <Label text="Reservas" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>
