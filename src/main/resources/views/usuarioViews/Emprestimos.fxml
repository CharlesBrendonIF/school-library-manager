<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifba.controller.features.usuario.EmprestimosController"
            stylesheets="@css/biblioqueue.css"
            prefWidth="900" prefHeight="700">

    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER">
                <Label text="BiblioQueue" styleClass="top-bar-title" HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox styleClass="user-header" alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Bem-vindo," styleClass="welcome-label"/>
                    <Label fx:id="lblNomeUsuario" text="Carregando..." styleClass="user-name-label"/>
                </VBox>
                <Button text="→" styleClass="logout-btn" onAction="#onLogout"
                        style="-fx-font-size: 20px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane styleClass="scroll-pane" fitToWidth="true"
                    style="-fx-background-color: #E8EEF7;">
            <VBox spacing="14" style="-fx-padding: 24 270 30 270; -fx-background-color: #E8EEF7;">

                <VBox spacing="2">
                    <Label text="Meus Empréstimos" styleClass="section-title"/>
                    <Label text="Livros em sua posse" styleClass="section-subtitle"/>
                </VBox>

                <HBox fx:id="alertaBloqueado"
                      styleClass="alert-card"
                      spacing="12"
                      alignment="TOP_LEFT"
                      visible="false"
                      managed="false">
                    <VBox alignment="CENTER" minWidth="32">
                        <Label text="⚠" style="-fx-font-size: 18px; -fx-text-fill: #DC2626;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="⚠" style="-fx-font-size: 13px; -fx-text-fill: #F59E0B;"/>
                            <Label text="Acesso Bloqueado" styleClass="alert-title"/>
                        </HBox>
                        <Label text="Você possui livros em atraso. Regularize suas devoluções para fazer novos empréstimos."
                               styleClass="alert-text"
                               wrapText="true"/>
                    </VBox>
                </HBox>

                <VBox fx:id="listaEmprestimosContainer" spacing="12"/>

                <VBox fx:id="emptyStateEmprestimos"
                      styleClass="empty-card"
                      spacing="16"
                      alignment="CENTER"
                      visible="false"
                      managed="false">
                    <VBox styleClass="empty-icon-circle" alignment="CENTER">
                        <Label text="📗" style="-fx-font-size: 26px;"/>
                    </VBox>
                    <Label text="Nenhum empréstimo ativo" styleClass="empty-title"/>
                    <Label text="Você não possui livros emprestados no momento"
                           styleClass="empty-subtitle" wrapText="true"
                           style="-fx-text-alignment: center;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox styleClass="bottom-bar" alignment="CENTER" spacing="0">

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavCatalogo" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="📖" style="-fx-font-size: 20px; -fx-text-fill: #94A3B8;"/>
                <Label text="Catálogo" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavEmprestimos" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="📗" style="-fx-font-size: 20px; -fx-text-fill: #1E3A8A;"/>
                <Label text="Empréstimos" style="-fx-font-size: 11px; -fx-text-fill: #1E3A8A; -fx-font-weight: bold;"/>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                  onMouseClicked="#onNavReservas" style="-fx-cursor: hand; -fx-padding: 6 0 6 0;">
                <Label text="🕐" style="-fx-font-size: 20px; -fx-text-fill: #94A3B8;"/>
                <Label text="Reservas" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>